# ============================================
# Smart Parking Monitor - Configuration
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#   nano .env

# --- Tapo C225 Camera ---
# TAPO_IP: Find this in your router's DHCP table or the Tapo app (Device Info).
TAPO_IP=192.168.1.100

# TAPO_USER / TAPO_PASSWORD: Camera Account credentials for RTSP streaming.
# Create these in the Tapo app: ⚙️ → Advanced Settings → Camera Account
TAPO_USER=your_camera_account_username
TAPO_PASSWORD=your_camera_account_password

# RTSP stream settings — defaults work for most C225 setups.
# TAPO_USER/TAPO_PASSWORD are used for RTSP streaming.
TAPO_RTSP_PORT=554
TAPO_STREAM_PATH=stream1

# TAPO_API_USER / TAPO_API_PASSWORD: Credentials for pytapo API (pan/tilt control).
# The pytapo API often requires DIFFERENT credentials than RTSP.
#
# There are two common scenarios:
#
#   Scenario A — Third-Party Compatibility ON (recommended, simplest):
#     Enable in Tapo app: ⚙️ → Advanced Settings → Third-Party Compatibility
#     Then set: TAPO_API_USER=admin  and  TAPO_API_PASSWORD=<your Camera Account password>
#
#   Scenario B — Third-Party Compatibility OFF:
#     pytapo needs your TP-Link cloud account (Tapo app login).
#     Set: TAPO_API_USER=your_tplink_email@example.com
#          TAPO_API_PASSWORD=your_tplink_cloud_password
#
# If left blank, TAPO_USER/TAPO_PASSWORD are used (works only if they match the API requirements).
TAPO_API_USER=admin
TAPO_API_PASSWORD=your_camera_account_password

# TAPO_CLOUD_USER / TAPO_CLOUD_PASSWORD: Legacy cloud credential fields (still supported).
# Prefer TAPO_API_USER / TAPO_API_PASSWORD above — they take priority.
# TAPO_CLOUD_USER=your_tplink_email@example.com
# TAPO_CLOUD_PASSWORD=your_tplink_cloud_password

# --- Anthropic Claude API ---
ANTHROPIC_API_KEY=sk-ant-your-key-here
# CLAUDE_MODEL: Full API model ID. Check https://docs.anthropic.com/en/docs/about-claude/models
# for the latest available model names.
CLAUDE_MODEL=claude-sonnet-4-5
CLAUDE_MAX_TOKENS=1024

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=7743829401:AAF-your-token-here
TELEGRAM_CHAT_ID=123456789

# --- Pushover Notifications ---
PUSHOVER_USER_KEY=your-pushover-user-key
PUSHOVER_API_TOKEN=your-pushover-api-token

# --- Monitoring Settings ---
CHECK_INTERVAL=180
CONFIDENCE_THRESHOLD=medium

# --- Quiet Hours (no Pushover notifications) ---
QUIET_HOURS_START=23
QUIET_HOURS_END=7

# --- Parking Zone (percentage of image frame) ---
PARKING_ZONE_TOP=30
PARKING_ZONE_BOTTOM=80
PARKING_ZONE_LEFT=20
PARKING_ZONE_RIGHT=80

# --- Street Scan Positions (comma-separated pan angles) ---
SCAN_POSITIONS=-60,-30,0,30,60
HOME_POSITION=0
SCAN_SETTLE_TIME=2.5

# --- HTTP API Server ---
API_HOST=0.0.0.0
API_PORT=8080
# Optional: set a secret key to require X-API-Key header on all API requests.
# Leave blank to keep the API open (suitable when protected by a VPN like Tailscale).
API_KEY=

# --- Database ---
DB_PATH=parking_history.db

# --- Geofencing (optional, for future use) ---
HOME_LAT=0.0
HOME_LON=0.0

# --- Street Context (customise for your specific street) ---
# Which side of the road has parking? "near" = camera side (same side as house), "far" = opposite side
STREET_PARKING_SIDE=near
# What restriction is on the opposite side? Options: none, single_yellow, double_yellow, no_parking
OPPOSITE_SIDE_RESTRICTION=double_yellow
# Your vehicle length in metres (used by AI to assess whether a gap is large enough to fit)
VEHICLE_LENGTH_METRES=4.5
# Minimum gap in metres to count as a free space
MIN_SPACE_METRES=5.0

# --- Auto-Calibration ---
# Enable auto-calibration on first boot (true/false). The system sweeps the camera,
# sends each frame to Claude for scoring, and picks the best scan angles automatically.
AUTO_CALIBRATE=true
# Re-calibrate every N days (0 = only on first boot or manual /calibrate)
CALIBRATION_INTERVAL_DAYS=30
# Minimum usefulness score (0-10) for an angle to be included in scan positions
CALIBRATION_MIN_USEFULNESS=6

# --- Safe Pan Bounds ---
# Constrains camera movement to angles where the street is visible through the window.
# Auto-calibration sets these automatically after each calibration run.
# Only override manually if you want to restrict the range further or haven't run
# calibration yet. Defaults to ±180 (full hardware range) if not set.
# SAFE_PAN_MIN=-60
# SAFE_PAN_MAX=60
